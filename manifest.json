{
    "manifest_version": 3,
    "name": "Scroll Position Indicator",
    "version": "1.0.0",
    "description": "A simple extension that shows the scroll position as a percentage.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage"
    ],
    "icons": {
        "16": "icons/icon_active_16.png",
        "32": "icons/icon_active_32.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Scroll Position Indicator On/Off",
        "default_icon": {
            "16": "icons/icon_active_16.png",
            "32": "icons/icon_active_32.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}
